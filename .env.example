#-----------------------------------------------------------
# AInalyst Configuration (.env.example)
# Copy this file to .env and modify as needed
#-----------------------------------------------------------

#-----------------------------------------------------------
# OpenAI API Configuration (REQUIRED)
#-----------------------------------------------------------
# Your OpenAI API key - required for embeddings and chat
OPENAI_API_KEY=your_openai_api_key_here

#-----------------------------------------------------------
# SEC EDGAR API Configuration (REQUIRED)
#-----------------------------------------------------------
# User agent for SEC EDGAR API (format: "Project Name your@email.com")
# SEC requires this information for their API rate limiting policies
EDGAR_USER_AGENT=AInalyst your@email.com

#-----------------------------------------------------------
# PostgreSQL Database Configuration
#-----------------------------------------------------------
# Database connection URI (for Docker setup, use "postgres" as the host)
POSTGRES_URI=postgresql://postgres:postgres@postgres:5432/finance_rag_db
# Individual database connection components (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=finance_rag_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

#-----------------------------------------------------------
# Data and Model Configuration
#-----------------------------------------------------------
# Path to the companies CSV file (relative to the project root)
COMPANIES_CSV_PATH=./companies.csv
# OpenAI embedding model name
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
# Embedding dimensions (must match the model: 1536 for text-embedding-3-small)
EMBEDDING_DIMENSION=1536
# OpenAI chat model for responses
DEFAULT_CHAT_MODEL=gpt-3.5-turbo

#-----------------------------------------------------------
# API and Logging Configuration
#-----------------------------------------------------------
# Optional API key for securing backend endpoints (leave blank to disable auth)
API_AUTH_KEY=
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

#-----------------------------------------------------------
# Frontend Configuration
#-----------------------------------------------------------
# API URL for frontend to connect to backend (default for local development)
REACT_APP_API_URL=http://localhost:8000